{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sub-pilot",
  "version": "0.1.7",
  "identifier": "com.sub-pilot.app",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "sub-pilot",
        "width": 1000,
        "height": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../resources/ffmpeg/ffmpeg": "resources/ffmpeg/ffmpeg",
      "../resources/models/base.pt": "resources/models/base.pt",
      "../resources/fonts/NotoSansCJKsc-Regular.otf": "resources/fonts/NotoSansCJKsc-Regular.otf"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
