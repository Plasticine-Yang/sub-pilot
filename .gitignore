# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Bundled binary resources — fetched via scripts/setup-resources.sh, never committed
/resources/ffmpeg/*
!/resources/ffmpeg/.gitkeep
/resources/models/*
!/resources/models/.gitkeep
/resources/fonts/*
!/resources/fonts/.gitkeep
# Dev whisper runtime (venv) — provisioned locally, never committed. The
# launcher script itself is tracked; the venv it resolves to is not.
/resources/whisper/venv/
/resources/whisper/build-venv/
/resources/whisper/windows/
