# Resolve dependencies against the public npm registry.
#
# Without this, running `npm install` on a machine whose user/global npmrc
# points at an internal mirror (e.g. bnpm.byted.org) rewrites package-lock.json
# with internal-only `resolved` URLs. `npm ci` then fails on public CI runners
# that cannot reach that mirror. Pinning the public registry here keeps the
# lockfile portable.
registry=https://registry.npmjs.org/
